---
import ProjectVisual from './ProjectVisual.astro';
import { projectCards } from '../data/site';
---
<section class="work-rail" id="work">
  <div class="section-header">
    <p class="section-label">Selected systems</p>
    <a href="/work#archive">View archive →</a>
  </div>
  <div class="project-grid">
    {projectCards.map((project) => (
      <article class="project-card">
        <ProjectVisual image={project.image} label={project.mediaLabel} title={project.title} />
        <h3>{project.title}</h3>
        <p>{project.copy}</p>
        <a href={`/work/${project.slug}`}>{project.action} →</a>
      </article>
    ))}
  </div>
</section>
