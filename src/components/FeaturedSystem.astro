---
import TrustFlow from './TrustFlow.astro';
---
<article class="featured-system" aria-label="Featured system: FrontierWarden">
  <div class="featured-copy">
    <p class="section-label">Featured system</p>
    <h2>FrontierWarden<span>.</span></h2>
    <p class="featured-tagline">Evidence-backed trust infrastructure for EVE Frontier operators.</p>
    <p class="featured-description">Brings indexed protocol evidence, event context, and operator policy into explainable evaluations for Frontier tools.</p>
    <p class="stack">SUI MOVE · RUST · POSTGRES · REACT · API</p>
    <div class="actions">
      <a class="action-button" href="/work/frontierwarden">View case study</a>
    </div>
  </div>
  <div class="flow-panel">
    <p>Trust evaluation flow</p>
    <TrustFlow />
  </div>
  <dl class="system-status">
    <div><dt>Stage</dt><dd><i></i> Testnet</dd></div>
    <div><dt>Network</dt><dd>Stillness</dd></div>
    <div><dt>Layers</dt><dd>Protocol · API · UI</dd></div>
    <div><dt>Authority</dt><dd>Tenant-defined</dd></div>
    <div><dt>Proof</dt><dd>Evidence-led</dd></div>
  </dl>
</article>
