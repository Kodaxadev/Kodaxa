---
import TrustFlow from './TrustFlow.astro';
---
<article class="featured-system" aria-label="Featured system: FrontierWarden">
  <div class="featured-copy">
    <p class="section-label">Featured system</p>
    <h2>FrontierWarden<span>.</span></h2>
    <p class="featured-tagline">Proof-aligned trust &amp; credit-risk infrastructure for the frontier.</p>
    <p class="featured-description">Evaluates actions, actors, and organizations using on-chain evidence and off-chain intel signal—producing verifiable trust signals the ecosystem can build on.</p>
    <div class="actions">
      <a class="action-button" href="/work/frontierwarden">View case study</a>
      <a class="text-link" href="https://frontierwarden.kodaxa.dev">Launch app <span aria-hidden="true">→</span></a>
    </div>
  </div>
  <figure class="featured-flow">
    <figcaption>Trust evaluation flow</figcaption>
    <TrustFlow />
  </figure>
  <dl class="system-status">
    <div><dt>Status</dt><dd><i></i> Live</dd></div>
    <div><dt>Network</dt><dd>Stillness / Testnet</dd></div>
    <div><dt>Modules</dt><dd>On-chain</dd></div>
    <div><dt>Data sources</dt><dd>28+</dd></div>
    <div><dt>Uptime</dt><dd>99.3%</dd></div>
  </dl>
</article>
