---
interface Props { type: 'shield' | 'cube' | 'lock' | 'radar' }
const { type } = Astro.props;
---
{type === 'shield' && (
  <svg class="principle-icon" viewBox="0 0 32 32" aria-hidden="true">
    <path d="M16 3 27 7v8c0 7-5 11.5-11 14C10 26.5 5 22 5 15V7Z" />
    <path d="m11 16 3.4 3.4L21 13" />
  </svg>
)}
{type === 'cube' && (
  <svg class="principle-icon" viewBox="0 0 32 32" aria-hidden="true">
    <path d="M16 3 27 9v14l-11 6L5 23V9Z" />
    <path d="M5 9l11 6 11-6M16 15v14" />
  </svg>
)}
{type === 'lock' && (
  <svg class="principle-icon" viewBox="0 0 32 32" aria-hidden="true">
    <rect x="7" y="14" width="18" height="14" rx="1.5" />
    <path d="M11 14v-3a5 5 0 0 1 10 0v3" />
    <circle cx="16" cy="20" r="1.7" />
  </svg>
)}
{type === 'radar' && (
  <svg class="principle-icon" viewBox="0 0 32 32" aria-hidden="true">
    <circle cx="16" cy="16" r="11" />
    <circle cx="16" cy="16" r="6" />
    <circle cx="16" cy="16" r="1.6" />
    <path d="M16 1v6M16 25v6M1 16h6M25 16h6" />
  </svg>
)}
