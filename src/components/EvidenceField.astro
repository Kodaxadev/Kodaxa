---
interface Props { ambient?: boolean }
const { ambient = false } = Astro.props;
---
<div class:list={['evidence-field', ambient && 'evidence-field--ambient']} aria-hidden="true">
  <canvas id="evidence-canvas" data-variant={ambient ? 'ambient' : 'hero'}></canvas>
  {!ambient && (
    <div class="flip-terminal" aria-hidden="true">
      <span class="flip-terminal__line flip-terminal__line--one">Evidence verified</span>
      <span class="flip-terminal__line flip-terminal__line--two">Context resolved</span>
      <span class="flip-terminal__line flip-terminal__line--three">Evidence aligned</span>
    </div>
  )}
</div>
<script>
  import '../scripts/evidence-field';
</script>
